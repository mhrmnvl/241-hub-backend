model AudienceGroup {
  id           String          @id @default(uuid()) @db.Uuid
  schoolUnitId String          @map("school_unit_id") @db.Uuid
  code         String          @db.VarChar(30)
  name         String          @db.VarChar(100)
  deletedAt    DateTime?       @map("deleted_at")

  schoolUnit SchoolUnit      @relation(fields: [schoolUnitId], references: [id], onDelete: Cascade)
  events     EventAudience[]

  @@unique([schoolUnitId, code])
  @@map("audience_groups")
}

model EventAudience {
  id              String        @id @default(uuid()) @db.Uuid
  eventId         String        @map("event_id") @db.Uuid
  audienceGroupId String        @map("audience_group_id") @db.Uuid

  event         Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  audienceGroup AudienceGroup @relation(fields: [audienceGroupId], references: [id])

  @@unique([eventId, audienceGroupId])
  @@map("event_audiences")
}

model Event {
  id           String          @id @default(uuid()) @db.Uuid
  schoolUnitId String          @map("school_unit_id") @db.Uuid
  title        String          @db.VarChar(200)
  description  String          @db.Text
  startTime    DateTime        @map("start_time") @db.Timestamptz()
  endTime      DateTime        @map("end_time") @db.Timestamptz()
  createdAt    DateTime        @default(now()) @map("created_at")
  deletedAt    DateTime?       @map("deleted_at")

  schoolUnit SchoolUnit      @relation(fields: [schoolUnitId], references: [id], onDelete: Cascade)
  audiences  EventAudience[]
  classrooms EventClassroom[]

  @@map("events")
}

model EventClassroom {
  id          String @id @default(uuid()) @db.Uuid
  eventId     String @map("event_id") @db.Uuid
  classroomId String @map("classroom_id") @db.Uuid

  event     Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  classroom Classroom @relation(fields: [classroomId], references: [id])

  @@unique([eventId, classroomId])
  @@map("event_classes")
}
