enum Day {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

model TimeSlotType {
  id           String     @id @default(uuid()) @db.Uuid
  schoolUnitId String     @map("school_unit_id") @db.Uuid
  code         String     @db.VarChar(30)
  name         String     @db.VarChar(100)
  deletedAt    DateTime?  @map("deleted_at")

  schoolUnit SchoolUnit @relation(fields: [schoolUnitId], references: [id], onDelete: Cascade)
  timeSlots  TimeSlot[]

  @@unique([schoolUnitId, code])
  @@map("time_slot_types")
}

model TimeSlot {
  id           String       @id @default(uuid()) @db.Uuid
  schoolUnitId String       @map("school_unit_id") @db.Uuid
  name         String       @db.VarChar(100)
  startTime    DateTime     @map("start_time") @db.Time(0)
  endTime      DateTime     @map("end_time") @db.Time(0)
  order        Int
  typeId       String       @map("type_id") @db.Uuid
  deletedAt    DateTime?    @map("deleted_at")

  schoolUnit   SchoolUnit   @relation(fields: [schoolUnitId], references: [id], onDelete: Cascade)
  type         TimeSlotType @relation(fields: [typeId], references: [id])
  schedules    Schedule[]

  @@map("time_slots")
}

model TeachingAssignment {
  id          String    @id @default(uuid()) @db.Uuid
  teacherId   String    @map("teacher_id") @db.Uuid
  classroomId String    @map("classroom_id") @db.Uuid
  subjectId   String    @map("subject_id") @db.Uuid
  semesterId  String    @map("semester_id") @db.Uuid
  deletedAt   DateTime? @map("deleted_at")

  teacher   Teacher   @relation(fields: [teacherId], references: [id])
  classroom Classroom @relation(fields: [classroomId], references: [id])
  subject   Subject   @relation(fields: [subjectId], references: [id])
  semester  Semester  @relation(fields: [semesterId], references: [id])

  schedules       Schedule[]
  assessmentItems AssessmentItem[]

  @@unique([teacherId, classroomId, subjectId, semesterId])
  @@index([teacherId])
  @@index([classroomId])
  @@index([subjectId])
  @@index([semesterId])
  @@map("teaching_assignments")
}

model Schedule {
  id                   String    @id @default(uuid()) @db.Uuid
  teachingAssignmentId String    @map("teaching_assignment_id") @db.Uuid
  timeSlotId           String    @map("time_slot_id") @db.Uuid
  day                  Day
  room                 String?   @db.VarChar(50)
  deletedAt            DateTime? @map("deleted_at")

  teachingAssignment TeachingAssignment @relation(fields: [teachingAssignmentId], references: [id])
  timeSlot           TimeSlot           @relation(fields: [timeSlotId], references: [id])

  attendances Attendance[]

  @@unique([teachingAssignmentId, day, timeSlotId])
  @@index([teachingAssignmentId])
  @@index([timeSlotId])
  @@map("schedules")
}
