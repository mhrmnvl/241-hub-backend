model FileCategory {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String?   @map("organization_id") @db.Uuid
  code           String    @db.VarChar(50)
  name           String    @db.VarChar(100)
  description    String?   @db.Text
  isSystem       Boolean   @default(false) @map("is_system")

  organization Organization? @relation(fields: [organizationId], references: [id])
  files        File[]

  @@unique([organizationId, code])
  @@map("file_categories")
}

model File {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  schoolUnitId   String?   @map("school_unit_id") @db.Uuid
  categoryId     String?   @map("category_id") @db.Uuid
  uploadedBy     String?   @map("uploaded_by") @db.Uuid
  filename       String    @db.VarChar(255)
  originalName   String    @map("original_name") @db.VarChar(255)
  mimeType       String    @map("mime_type") @db.VarChar(100)
  sizeBytes      Int       @map("size_bytes")
  storageKey     String    @map("storage_key") @db.VarChar(500)
  createdAt      DateTime  @default(now()) @map("created_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization  @relation(fields: [organizationId], references: [id])
  schoolUnit   SchoolUnit?   @relation(fields: [schoolUnitId], references: [id])
  category     FileCategory? @relation(fields: [categoryId], references: [id])
  uploader     User?         @relation(fields: [uploadedBy], references: [id])

  @@index([organizationId])
  @@index([schoolUnitId])
  @@index([categoryId])
  @@map("files")
}
