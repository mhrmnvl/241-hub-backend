enum StudentStatus {
  ACTIVE
  TRANSFERRED
  DROPPED
  GRADUATED
}

model Student {
  id               String        @id @default(uuid()) @db.Uuid
  userId           String        @unique @map("user_id") @db.Uuid
  nis              String        @unique @db.VarChar(20)
  nisn             String        @unique @db.VarChar(20)
  status           StudentStatus @default(ACTIVE)
  gradeId          String?       @map("grade_id") @db.Uuid
  deletedAt        DateTime?     @map("deleted_at")

  addresses             Address[]
  parents               StudentParent[]
  enrollments            StudentEnrollment[]
  graduations            StudentGraduation[]
  classroomPresidencies      ClassroomStructure[] @relation("ClassroomPresident")
  classroomVicePresidencies  ClassroomStructure[] @relation("ClassroomVicePresident")
  classroomSecretaryRoles    ClassroomStructure[] @relation("ClassroomSecretary")
  classroomTreasurerRoles    ClassroomStructure[] @relation("ClassroomTreasurer")

  user           User            @relation(fields: [userId], references: [id])
  grade          Grade?          @relation(fields: [gradeId], references: [id])

  @@index([status])
  @@index([gradeId])
  @@map("students")
}
