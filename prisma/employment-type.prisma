model EmploymentType {
  id           String      @id @default(uuid()) @db.Uuid
  schoolUnitId String      @map("school_unit_id") @db.Uuid
  code         String      @db.VarChar(20)
  name         String      @db.VarChar(100)
  deletedAt    DateTime?   @map("deleted_at")

  schoolUnit   SchoolUnit  @relation(fields: [schoolUnitId], references: [id], onDelete: Cascade)
  teachers     Teacher[]

  @@unique([schoolUnitId, code])
  @@map("employment_types")
}
