model PositionCategory {
  id        String     @id @default(uuid()) @db.Uuid
  code      String     @unique @db.VarChar(30)
  name      String     @db.VarChar(100)
  deletedAt DateTime?  @map("deleted_at")
  positions Position[]

  @@map("position_categories")
}

model Position {
  id         String           @id @default(uuid()) @db.Uuid
  name       String           @unique @db.VarChar(100)
  categoryId String           @map("category_id") @db.Uuid
  isActive   Boolean          @default(true) @map("is_active")
  deletedAt  DateTime?        @map("deleted_at")

  category         PositionCategory  @relation(fields: [categoryId], references: [id])
  teacherPositions TeacherPosition[]

  @@map("positions")
}

model TeacherPosition {
  id         String    @id @default(uuid()) @db.Uuid
  teacherId  String    @map("teacher_id") @db.Uuid
  positionId String    @map("position_id") @db.Uuid
  hireDate   DateTime  @map("hire_date") @db.Date
  isPrimary  Boolean   @default(false) @map("is_primary")
  deletedAt  DateTime? @map("deleted_at")

  teacher  Teacher  @relation(fields: [teacherId], references: [id])
  position Position @relation(fields: [positionId], references: [id])

  @@unique([teacherId, positionId, hireDate])
  @@map("teacher_positions")
}

