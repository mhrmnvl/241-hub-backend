enum SchoolUnitStatus {
  PRIVATE
  PUBLIC
}

model SchoolUnitType {
  id       String  @id @default(uuid()) @db.Uuid
  code     String  @unique @db.VarChar(20)
  name     String  @db.VarChar(100)
  isActive Boolean @default(true) @map("is_active")

  schoolUnits SchoolUnit[]

  @@map("school_unit_types")
}

model SchoolUnit {
  id             String                  @id @default(uuid()) @db.Uuid
  organizationId String                  @map("organization_id") @db.Uuid
  typeId         String?                 @map("type_id") @db.Uuid
  name           String                  @db.VarChar(200)
  surname        String                  @db.VarChar(200)
  nsm            String                  @db.VarChar(20)
  npsn           String                  @db.VarChar(20)
  status         SchoolUnitStatus
  npwp           String                  @db.VarChar(30)
  phone          String                  @db.VarChar(15)
  email          String                  @db.VarChar(255)
  website        String                  @db.VarChar(255)
  isActive       Boolean                 @default(true) @map("is_active")
  subdomain      String?                 @unique @db.VarChar(100)
  customDomain   String?                 @unique @map("custom_domain") @db.VarChar(255)
  socialMedias    SchoolUnitSocialMedia[]
  addresses       Address[]
  deletedAt       DateTime?               @map("deleted_at")

  organization    Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type            SchoolUnitType?         @relation(fields: [typeId], references: [id])
  files           File[]
  academicYears   AcademicYear[]
  curricula       Curricula[]
  users           User[]
  employmentTypes EmploymentType[]
  timeSlotTypes   TimeSlotType[]
  timeSlots       TimeSlot[]
  audienceGroups  AudienceGroup[]
  events          Event[]

  @@unique([organizationId, npsn])
  @@map("school_units")
}

