enum UserGender {
  MALE
  FEMALE
}

enum Religion {
  ISLAM
  PROTESTANT
  CATHOLIC
  HINDU
  BUDDHIST
  CONFUCIAN
}

enum BloodType {
  A
  B
  AB
  O
  A_PLUS
  A_MINUS
  B_PLUS
  B_MINUS
  AB_PLUS
  AB_MINUS
  O_PLUS
  O_MINUS
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

model Profile {
  id            String         @id @default(uuid()) @db.Uuid
  userId        String         @unique @map("user_id") @db.Uuid
  name          String         @db.VarChar(100)
  nik           String         @unique @db.VarChar(16)
  gender        UserGender
  birthPlace    String         @map("birth_place") @db.VarChar(100)
  birthDate     DateTime       @map("birth_date") @db.Date
  email         String?        @unique @db.VarChar(255)
  phone         String?        @unique @db.VarChar(15)
  religion      Religion?
  bloodType     BloodType?     @map("blood_type")
  maritalStatus MaritalStatus? @map("marital_status")
  noKk          String?        @map("no_kk") @db.VarChar(16)
  npwp          String?        @db.VarChar(20)

  socialMedias         ProfileSocialMedia[]
  achievements         Achievement[]
  scholarships         Scholarship[]
  educationalHistories EducationalHistory[]

  user User @relation(fields: [userId], references: [id])

  @@map("profiles")
}
