# Only fail CI on HIGH severity vulnerabilities.
# The remaining MODERATE advisories are unfixable without breaking changes:
#
#   ajv (ReDoS)  — inside @nestjs/cli → @angular-devkit (dev build tool, never deployed)
#   lodash (PP)  — inside @prisma/dev → @chevrotain (Prisma CLI, never deployed)
#
# These are upstream issues. Track at:
#   https://github.com/nestjs/nest-cli/issues
#   https://github.com/prisma/prisma/issues
audit-level=high
public-hoist-pattern[]=*prisma*
shamefully-hoist=true
